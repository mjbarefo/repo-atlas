{
  "name": "atlas-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "generate:types": "json2ts -i ../shared/schemas/map.schema.json -o src/generated/map.ts && json2ts -i ../shared/schemas/trace.schema.json -o src/generated/trace.ts && json2ts -i ../shared/schemas/impact.schema.json -o src/generated/impact.ts",
    "check:generated": "node scripts/check-generated.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "elkjs": "^0.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
