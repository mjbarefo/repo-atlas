{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/map.schema.json",
  "title": "MapArtifact",
  "description": "A deterministic, evidence-backed map of a source repository.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repo", "nodes", "edges", "levels"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "repo": { "$ref": "#/$defs/repository" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "levels": { "$ref": "#/$defs/levels" },
    "capabilities": { "$ref": "#/$defs/capabilities" }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported_edge_kinds"],
      "properties": {
        "supported_edge_kinds": {
          "description": "Edge kinds the analyzer actually emits. A kind present in an edge's `kind` enum but absent here is declared in the contract but not yet produced.",
          "type": "array",
          "items": { "enum": ["imports", "calls", "inherits"] },
          "uniqueItems": true
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "commit", "generated_at"],
      "properties": {
        "root": { "type": "string" },
        "commit": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loc", "fan_in", "fan_out"],
      "properties": {
        "loc": { "type": "integer", "minimum": 0 },
        "fan_in": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of distinct nodes that depend on this node (a neighbor count, not import volume; see edge `weight` for volume)."
        },
        "fan_out": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of distinct nodes this node depends on (a neighbor count, not import volume; see edge `weight` for volume)."
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "summary",
        "prose_source",
        "children",
        "files",
        "metrics"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["component", "module", "file"] },
        "role": {
          "description": "Provenance class of the underlying file(s). Only role \"source\" files form and name modules/components; non-source nodes stay in the map but are excluded from architecture layering.",
          "enum": ["source", "test", "fixture", "generated", "vendored"],
          "default": "source"
        },
        "label": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "prose_source": { "enum": ["heuristic", "llm"] },
        "children": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "metrics": { "$ref": "#/$defs/metrics" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "kind", "evidence"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["imports", "calls", "inherits"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "weight": {
          "description": "Number of distinct import sites backing this edge (equal to the count of evidence entries).",
          "type": "integer",
          "minimum": 1
        },
        "label": { "type": "string" }
      }
    },
    "levels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "component", "module"],
      "properties": {
        "system": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "component": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "module": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}

